OPENROUTER_API_KEY=

# Default model if the UI leaves model blank
DEFAULT_MODEL=openai/gpt-4o-mini

# OpenRouter API settings
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=PromptLab AI

# Local development database
DATABASE_URL=sqlite:///./promptlab.db

# Production database for Vercel
# Paste your full Postgres connection string here.
# Example:
# POSTGRES_URL=postgresql+psycopg://username:password@host:5432/prompteng
POSTGRES_URL=

# Allowed frontend origins
# Local only:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# Vercel frontend only:
# CORS_ORIGINS=https://your-frontend-project.vercel.app
#
# Local + Vercel frontend:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-project.vercel.app
