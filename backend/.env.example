OPENROUTER_API_KEY=
# Optional: default chat model (OpenRouter slug, e.g. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet)
DEFAULT_MODEL=openai/gpt-4o-mini
# Optional: override API base (rarely needed)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: attribution for OpenRouter rankings dashboard
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=PromptLab AI
# For local development:
DATABASE_URL=sqlite:///./promptlab.db
# For Vercel Postgres or any hosted Postgres, prefer POSTGRES_URL:
# POSTGRES_URL=postgresql+psycopg://user:password@host:5432/dbname
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
