# Leave empty in development to use Vite proxy to backend (same origin /api).
# Backend default dev URL is http://127.0.0.1:8010 (see backend/run_dev.ps1).
# Override only if your API runs elsewhere:
# VITE_API_PROXY=http://127.0.0.1:8010
#
# For production static hosting (e.g. Vercel), set to your Render API URL:
# VITE_API_URL=https://your-api.onrender.com
